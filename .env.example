# Hugging Face model id for the Qwen2-VL nav-assistant captioner.
MODEL_NAME=MarinaMohsen/qwen2-vl-2b-nav-assistant

# Max generated tokens per caption (lower = faster).
MAX_NEW_TOKENS=64

# Instruction sent with every frame (Qwen2-VL is an instruct model). Tune to match the fine-tune.
CAPTION_PROMPT=Describe the path ahead and any obstacles or hazards for a visually impaired person.

# Comma-separated CORS origins allowed to call the service ("*" allows all).
# In production, set this to the Spring backend origin.
ALLOWED_ORIGINS=*

# Port to listen on (Hugging Face Spaces require 7860).
PORT=7860
