# Hugging Face model id for the Qwen2-VL nav-assistant captioner.
MODEL_NAME=MarinaMohsen/qwen2-vl-2b-nav-assistant

# Max generated tokens per caption — a ceiling, not a target (lower = faster; ~linear decode time).
MAX_NEW_TOKENS=40

# Instruction sent with every frame, as a SYSTEM message (Qwen2-VL is an instruct model — role and
# wording both matter). Default mirrors the model author's nav-assistant Space prompt.
CAPTION_PROMPT=You are a real-time assistant for a visually impaired user. Describe the scene accurately in one or two short sentences. If there is a hazard, obstacle, or danger ahead, describe what it is and its location (e.g., 'on the left'). If the path is clear, simply describe the environment and surroundings naturally. Do not say 'no hazards' or 'the scene is safe', instead describe the scene like objects and people...

# Comma-separated CORS origins allowed to call the service ("*" allows all).
# In production, set this to the Spring backend origin.
ALLOWED_ORIGINS=*

# Port to listen on (Hugging Face Spaces require 7860).
PORT=7860
